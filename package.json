	"author": "nirholas <support@three.ws>",
	"license": "SEE LICENSE IN LICENSE",
	"homepage": "https://three.ws",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/nirholas/portfolio-mcp.git"
	},
	"bugs": {
		"url": "https://github.com/nirholas/three.ws/issues"
	},
	"keywords": [
		"mcp",
		"model-context-protocol",
		"three.ws",
		"portfolio",
		"pnl",
		"trades",
		"wallet",
		"balances",
		"solana",
		"transfer",
		"ai-agent"
	],
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"src",
		"server.json",
		"README.md",
